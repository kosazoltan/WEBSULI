# ============================================
# WEBSULI - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# === CORE (Required) ===
DATABASE_URL=postgresql://user:password@host/dbname
SESSION_SECRET=generate-a-random-64-char-string-here
PORT=5000
NODE_ENV=development

# === DEPLOYMENT URLs ===
# BASE_URL: Used for Google OAuth callback URL
# In production (Render+Vercel): set to the Vercel frontend URL
# Example: https://websuli.vercel.app
BASE_URL=http://localhost:5000

# FRONTEND_URL: Used for CORS allowed origins
# In production (Render+Vercel): set to the Vercel frontend URL
# Example: https://websuli.vercel.app
# FRONTEND_URL=

# CUSTOM_DOMAIN: Your custom domain (optional)
# Example: websuli.org
# CUSTOM_DOMAIN=

# === GOOGLE OAUTH (Required for Google login) ===
# Get these from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === ADMIN ===
# First user logging in with this email gets admin rights automatically
# ADMIN_EMAIL=admin@example.com

# === AI INTEGRATION (Optional) ===
# OpenAI API key from https://platform.openai.com/api-keys
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# Anthropic (Claude) API key from https://console.anthropic.com/settings/keys
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# === EMAIL - Resend (Optional) ===
# Get API key from https://resend.com/api-keys
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=WEBSULI <noreply@websuli.org>

# === PUSH NOTIFICATIONS (Optional) ===
# Generate VAPID keys: npx web-push generate-vapid-keys
# PUBLIC_VAPID_KEY=
# PRIVATE_VAPID_KEY=

# === DEVELOPMENT ONLY ===
# Separate dev database (optional - uses DATABASE_URL if not set)
# DEV_DATABASE_URL=
