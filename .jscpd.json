{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schema.json",
  "threshold": 10,
  "minLines": 5,
  "minTokens": 50,
  "reporters": ["console"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.min.js",
    "**/package-lock.json"
  ],
  "absolute": true
}
